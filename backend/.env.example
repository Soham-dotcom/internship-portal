# Backend environment variables
NODE_ENV=production
PORT=5000
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/spit-internships
# Alternatively, set MONGO_URI instead of MONGODB_URI
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/spit-internships
JWT_SECRET=change_me
MAIL_CREDENTIALS_SECRET=change_me
FRONTEND_URL=https://your-frontend-domain.vercel.app
# Optional: allow multiple frontend origins (comma-separated)
# FRONTEND_URLS=https://your-frontend-domain.vercel.app,https://your-preview.vercel.app
SHARED_DB_NAME=spit-common
YEAR_DB_PREFIX=spit-internships-
ACADEMIC_YEARS=2024,2025,2026
SMTP_SERVICE=
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
